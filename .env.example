# ============================================================
# Lana Stone — переменные окружения для продакшн-сервера (Timeweb)
# ============================================================
# Этот файл — шаблон. На сервере создайте файл .env (без .example)
# и подставьте реальные значения. .env в git НЕ коммитим.

# --- AI примерка (OpenRouter) ---
# Получить ключ: https://openrouter.ai/keys
# Пополнить баланс: https://openrouter.ai/credits
OPENROUTER_API_KEY=sk-or-v1-...

# --- Email (Resend) ---
# Получить ключ: https://resend.com/api-keys
RESEND_API_KEY_DIRECT=re_...

# --- Порт, на котором слушает Node-сервер ---
# Nginx будет проксировать с :443 (HTTPS) на этот порт
PORT=3000
