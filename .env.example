# ============================================================
# Lana Stone — переменные окружения для Timeweb Cloud (Docker)
# ============================================================
# Этот файл — шаблон. На сервере/в панели Timeweb создайте .env (или
# пропишите переменные через UI) и подставьте реальные значения.
# .env в git НЕ коммитим.

# --- AI примерка (OpenRouter) ---
# Получить ключ: https://openrouter.ai/keys
# Пополнить баланс: https://openrouter.ai/credits
OPENROUTER_API_KEY=sk-or-v1-...

# --- Email (Resend) ---
# Получить ключ: https://resend.com/api-keys
RESEND_API_KEY_DIRECT=re_...

# --- Email получателя заявок (лиды и заказы) ---
ADMIN_EMAIL=lanastonevrn@gmail.com

# --- Сетевые настройки Node-сервера ---
# HOST=0.0.0.0 обязателен в Docker, чтобы слушать снаружи контейнера
HOST=0.0.0.0
PORT=3000
NODE_ENV=production
